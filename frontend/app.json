{
  "expo": {
    "name": "RollCall",
    "slug": "rollcall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/RollCall.png",
    "scheme": "rollcall",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/RollCall.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.kevinsidd.rollcall"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/RollCall.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/RollCall.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
